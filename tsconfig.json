{
  "compilerOptions": {
    "target": "es2019",
    "module": "commonjs",
    "moduleResolution": "bundler",
    "outDir": "./dist/",
    "rootDir": "./src/",
    "sourceMap": true,
    "strict": false,
    "strictNullChecks": false,
    "esModuleInterop": true,
    "lib": ["es2021", "dom"],
    "resolveJsonModule": true
  },
  "include": ["src/**/*"]
}